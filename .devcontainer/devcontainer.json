{
  "name": "Python + Node.js",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",

 "secrets": {
    "NH4_API_KEY": {
      "description": "gid of the published Google Sheet tab"
    },
    
    "DH3_API_KEY": {
      "description": "Fouita widget UID"
    }
  },

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  },

  "remoteEnv": {
    "NH4_API_KEY": "${localEnv:NH4_API_KEY}",
    "DH3_API_KEY": "${localEnv:DH3_API_KEY}"
  },

  "remoteUser": "vscode",

  "postCreateCommand": "pip install -r requirements.txt && bash .devcontainer/setup-mcp.sh"
}
