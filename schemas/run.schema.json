{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "run.schema.json",
  "title": "Run",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "kennel", "runno", "date", "location"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name of the hash club"
    },
    "kennel": {
      "type": "string",
      "description": "Short identifier for the hash club (matches config.yaml key)"
    },
    "runno": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "description": "Run number"
    },
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date YYYY-MM-DD"
    },
    "time": {
      "type": "string",
      "pattern": "^\\d{2}:\\d{2}$",
      "description": "ISO 8601 time HH:MM"
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "postcode": { "type": "string" },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 },
        "osgrid": {
          "type": "string",
          "pattern": "^[A-Z]{2}[0-9]{4}([0-9]{2}([0-9]{2}([0-9]{2})?)?)?$"
        },
        "w3s": {
          "type": "string",
          "pattern": "^[a-z]+\\.[a-z]+\\.[a-z]+$"
        }
      }
    },
    "oninn": {
      "type": "string",
      "description": "Venue name for the on-in"
    },
    "hares": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Array of hare names"
    },
    "notes": {
      "type": "string",
      "description": "Free text"
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "URL associated with the event"
    }
  }
}
