{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "log.schema.json",
  "title": "ScraperLog",
  "type": "object",
  "additionalProperties": false,
  "required": ["timestamp", "site", "scraper_version", "status", "ttl_before", "ttl_after", "records_parsed"],
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "site": { "type": "string" },
    "scraper_version": { "type": "string" },
    "status": { "type": "string", "enum": ["success", "failure"] },
    "failure_mode": {
      "type": ["string", "null"],
      "enum": ["TRANSIENT", "AUTH", "FATAL", null]
    },
    "ttl_before": { "type": "integer" },
    "ttl_after": { "type": "integer" },
    "records_parsed": { "type": "integer", "minimum": 0 },
    "exception": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string" },
        "message": { "type": "string" },
        "stacktrace": { "type": "array", "items": { "type": "string" } }
      }
    },
    "request": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string" },
        "method": { "type": "string" },
        "headers": { "type": "object" }
      }
    },
    "response": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "status_code": { "type": ["integer", "null"] },
        "headers": { "type": "object" },
        "body_size_bytes": { "type": "integer" },
        "body_truncated": { "type": "boolean" },
        "body": { "type": "string" }
      }
    }
  }
}
