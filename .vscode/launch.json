    "version": "0.2.0",
    "configurations": [
        {
            "name": "Scrape All",
            "type": "debugpy",
            "request": "launch",
            "program": "run.py",
            "console": "integratedTerminal",
            "args": "--all"
        },
        {
            "name": "Scrape All - Dry Run",
            "type": "debugpy",
            "request": "launch",
            "program": "run.py",
            "console": "integratedTerminal",
            "args": "--dry-run"
        },
        {
            "name": "Generate JSON",
            "type": "debugpy",
            "request": "launch",
            "program": "generate.py",
            "console": "integratedTerminal",
            "args": ""
        },
        {
            "name": "Generate HTML File",
            "type": "debugpy",
            "request": "launch",
            "program": "generate.py",
            "console": "integratedTerminal",
            "args": "--html output/index.html "
        }
    ]
}