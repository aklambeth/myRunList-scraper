# Project aliases
alias run='python3 run.py'
alias dry-run='python3 run.py --dry-run'
alias gen='generate.py'
alias gen-html='python3 generate.py --html output/index.html --transform latest'
alias gen-json='generate.py --json output/runs.json --transform latest'
alias reset='python3 run.py --reset'
alias status='python3 run.py --status'
alias logs='python3 run.py --getlogs'
